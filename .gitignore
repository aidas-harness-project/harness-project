# Obsidian workspace/cache (개인 UI 상태 — 지식이 아님)
.obsidian/

# The `wiki` knowledge base is a SEPARATE repo, never part of this one. The
# templates the pipeline actually consumes were vendored into `templates/` on
# 2026-07-13 to break the live dependency (each carries a `provenance` note).
# A local `wiki/` clone must never be re-added -- `git add` on a nested repo
# silently records a URL-less gitlink (mode 160000) that breaks fresh clones.
wiki/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# Claude Code local settings
.claude/settings.local.json

# Pipeline execution data (copy of source-cases/ + intermediate outputs -- originals version-controlled in source-cases/)
data/

# Workspace Data with each run's report written by agent
_workspace/

# Pipeline contract outputs -- per-run generated artifacts, not source of truth
outputs/

# archived legacy files
archive/

# Transient file locks (P5) -- must never be committed
*.lock

# Shared temp zip (schemas/ is the source of truth)
schemas.zip

# ocr_extract.py's project-local scratch (page images) -- transient, cleaned up on exit
_ocr_scratch/
_redaction_scratch/

# graphify knowledge-graph build output -- regenerable from the corpus, not source
graphify-out/

# Pipeline viewer frontend -- build artifacts and venvs, not source
frontend/web/node_modules/
frontend/web/dist/
frontend/web/dist-static/
frontend/backend/venv/
frontend/backend/_uploads/
frontend/backend/_runs.json
frontend/backend/_run_logs/
