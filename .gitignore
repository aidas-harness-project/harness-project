# Obsidian workspace/cache (개인 UI 상태 — 지식이 아님)
.obsidian/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# Claude Code local settings
.claude/settings.local.json

# Pipeline execution data (copy of source-cases/ + intermediate outputs -- originals version-controlled in source-cases/)
data/

# Per-step run backups (P10) -- regenerable snapshots, not source of truth
outputs/*/_backups/

# Transient file locks (P5) -- must never be committed
*.lock

# Shared temp zip (schemas/ is the source of truth)
schemas.zip

# ocr_extract.py's project-local scratch (page images) -- transient, cleaned up on exit
_ocr_scratch/

# Pipeline viewer frontend -- build artifacts and venvs, not source
frontend/web/node_modules/
frontend/web/dist/
frontend/backend/venv/
frontend/backend/_uploads/
frontend/backend/_runs.json
frontend/backend/_run_logs/