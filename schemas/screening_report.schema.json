{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "screening_report.schema.json",
  "title": "screening_report.json -- initial screening briefing v0.1",
  "description": "Machine-readable screening report assembled from prior-stage outputs. Produced by screening-report; screening_report.md (the human-facing render) is generated from this JSON via the document-assembly tool. Section structure follows templates/screening-report.md's 7-section shape.",
  "allOf": [
    { "$ref": "common_component_output.schema.json" },
    {
      "type": "object",
      "properties": {
        "report_path": {
          "type": "string",
          "description": "Path to the rendered .md report. outputs/CASE_XXX/screening_report.md"
        },
        "case_summary": { "$ref": "#/$defs/case_summary" },
        "insurer_position": { "$ref": "#/$defs/insurer_position" },
        "key_issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/key_issue" }
        },
        "inconsistencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/inconsistency" }
        },
        "missing_documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/missing_document" }
        },
        "review_points": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_point" }
        },
        "preliminary_assessment": { "$ref": "#/$defs/preliminary_assessment" },
        "draft_writer_input_summary": { "$ref": "#/$defs/draft_writer_input_summary" }
      },
      "required": [
        "report_path",
        "case_summary",
        "insurer_position",
        "key_issues",
        "inconsistencies",
        "missing_documents",
        "review_points",
        "preliminary_assessment"
      ]
    }
  ],
  "$defs": {
    "case_summary": {
      "type": "object",
      "description": "Case overview section. Source: extracted_claim_fields, coverage_result, case_type_result.",
      "properties": {
        "case_type": {
          "type": "string",
          "description": "Case type -- e.g. permanent-disability, diagnosis/surgery-cost, out-of-pocket medical, liability, other. See pipeline.md's taxonomy."
        },
        "main_diagnosis": { "type": "string" },
        "kcd_code": { "type": ["string", "null"] },
        "accident_date": { "type": ["string", "null"], "format": "date" },
        "onset_date": { "type": ["string", "null"], "format": "date" },
        "treatment_period": {
          "type": ["object", "null"],
          "properties": {
            "start_date": { "type": "string", "format": "date" },
            "end_date": { "type": ["string", "null"], "format": "date" }
          },
          "required": ["start_date"]
        },
        "claim_coverages": {
          "type": "array",
          "description": "Standard coverage names -- see pipeline.md's taxonomy.",
          "items": { "type": "string" }
        }
      },
      "required": ["case_type", "main_diagnosis", "claim_coverages"]
    },
    "insurer_position": {
      "type": "object",
      "description": "Insurer's determination section. Source: denial_reason_result (from denial-response, consumed as a dependency -- see pipeline.md).",
      "properties": {
        "has_denial_or_reduction": { "type": "boolean" },
        "main_reason_code": {
          "anyOf": [
            { "$ref": "common_component_output.schema.json#/$defs/taxonomy_code" },
            { "type": "null" }
          ]
        },
        "main_reason_label": { "type": ["string", "null"] },
        "summary": {
          "type": ["string", "null"],
          "description": "Summary of the insurer's position -- hedged, non-definitive phrasing."
        },
        "reduction_amount": { "type": ["number", "null"], "minimum": 0 }
      },
      "required": ["has_denial_or_reduction"]
    },
    "key_issue": {
      "type": "object",
      "description": "A core issue for review.",
      "properties": {
        "issue_id": { "type": "string", "pattern": "^ISSUE_[0-9]+$" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "related_documents": {
          "type": "array",
          "items": { "$ref": "common_component_output.schema.json#/$defs/document_id" }
        },
        "review_required": { "type": "boolean" },
        "reviewer_role": { "$ref": "common_component_output.schema.json#/$defs/reviewer_role" }
      },
      "required": ["issue_id", "title", "description"]
    },
    "inconsistency": {
      "type": "object",
      "description": "A cross-document inconsistency. Source: evidence_validation_result / the conflict ledger (see harness-guardrails P6) -- detailed doc_a/doc_b value comparison and resolution live there; this is a summary plus document tracing.",
      "properties": {
        "field": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "$ref": "common_component_output.schema.json#/$defs/severity" },
        "related_documents": {
          "type": "array",
          "minItems": 2,
          "description": "The documents being compared where the inconsistency was found.",
          "items": { "$ref": "common_component_output.schema.json#/$defs/document_id" }
        },
        "review_required": { "type": "boolean" }
      },
      "required": ["field", "description", "severity"]
    },
    "missing_document": {
      "type": "object",
      "description": "A document recommended for follow-up request.",
      "properties": {
        "document_type": {
          "type": "string",
          "description": "Standard code or specific document name. e.g. disability_certificate"
        },
        "reason": { "type": "string" }
      },
      "required": ["document_type", "reason"]
    },
    "review_point": {
      "type": "object",
      "description": "A point flagged for expert review.",
      "properties": {
        "point": { "type": "string" },
        "reviewer_role": { "$ref": "common_component_output.schema.json#/$defs/reviewer_role" },
        "priority": { "$ref": "common_component_output.schema.json#/$defs/severity" }
      },
      "required": ["point", "reviewer_role", "priority"]
    },
    "preliminary_assessment": {
      "type": "object",
      "description": "Preliminary judgment. This is the pipeline's most judgment-heavy output, so evidence-linking and review routing are mandatory here -- review_required defaults to true and reviewer_role to 손해사정사 for this section.",
      "properties": {
        "feasibility": {
          "enum": ["high", "medium", "low"]
        },
        "difficulty": {
          "enum": ["high", "medium", "low"]
        },
        "priority_review_points": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "rationale_evidence_references": {
          "type": "array",
          "description": "Evidence backing this assessment. Empty is treated as source_grounded: false.",
          "items": { "$ref": "common_component_output.schema.json#/$defs/evidence_reference" }
        }
      },
      "required": ["feasibility", "difficulty", "priority_review_points"]
    },
    "draft_writer_input_summary": {
      "type": "object",
      "description": "Summary handed to draft-report. template_id is decided by case-type classification.",
      "properties": {
        "recommended_template_id": { "type": "string" },
        "sections_to_emphasize": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["recommended_template_id"]
    }
  }
}
