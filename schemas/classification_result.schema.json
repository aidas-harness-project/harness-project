{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "classification_result.schema.json",
  "title": "classification_result.json — 문서 유형 분류 결과 v0.1",
  "description": "각 문서에 유형 이름표를 붙인 결과. DocumentPipelineAgent의 DocumentClassification 단계가 생성. Field Extraction·Policy·Denial Reason 단계가 문서 선별에 사용한다.",
  "allOf": [
    { "$ref": "common_component_output.schema.json" },
    {
      "type": "object",
      "properties": {
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/classified_document" }
        }
      },
      "required": ["documents"]
    }
  ],
  "$defs": {
    "classified_document": {
      "type": "object",
      "properties": {
        "document_id": { "$ref": "common_component_output.schema.json#/$defs/document_id" },
        "predicted_document_type": { "$ref": "common_component_output.schema.json#/$defs/document_type" },
        "document_type_label": {
          "type": "string",
          "description": "한국어 표시명. 예: 진단서, 보험사 안내문"
        },
        "confidence": { "$ref": "common_component_output.schema.json#/$defs/confidence" },
        "candidate_types": {
          "type": "array",
          "description": "confidence 내림차순 후보 목록. 첫 항목은 predicted_document_type과 일치해야 한다.",
          "items": {
            "type": "object",
            "properties": {
              "document_type": { "$ref": "common_component_output.schema.json#/$defs/document_type" },
              "confidence": { "$ref": "common_component_output.schema.json#/$defs/confidence" }
            },
            "required": ["document_type", "confidence"]
          }
        },
        "evidence_references": {
          "type": "array",
          "minItems": 1,
          "description": "분류 근거 문장. 문서 컨텍스트가 자명하므로 document_id 생략 가능.",
          "items": { "$ref": "common_component_output.schema.json#/$defs/evidence_reference" }
        },
        "review_required": { "type": "boolean" },
        "reviewer_role": { "$ref": "common_component_output.schema.json#/$defs/reviewer_role" }
      },
      "required": ["document_id", "predicted_document_type", "confidence", "evidence_references", "review_required"]
    }
  }
}
