{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extracted_claim_fields.schema.json",
  "title": "extracted_claim_fields.json -- core claim fact card v0.1",
  "description": "Structured core facts extracted from claim documents. Produced by claim-analysis's checkpoint 1 (Claim Field Extraction). Field structure is fixed to three shapes -- single-value (value_field), date (date_field), period (period_field). No other shape is permitted.",
  "allOf": [
    { "$ref": "common_component_output.schema.json" },
    {
      "type": "object",
      "properties": {
        "fields": {
          "type": "object",
          "properties": {
            "diagnosis_name": { "$ref": "#/$defs/value_field" },
            "kcd_code": { "$ref": "#/$defs/value_field" },
            "accident_date": { "$ref": "#/$defs/date_field" },
            "onset_date": { "$ref": "#/$defs/date_field" },
            "surgery_name": { "$ref": "#/$defs/value_field" },
            "hospital_name": { "$ref": "#/$defs/value_field" },
            "treatment_period": { "$ref": "#/$defs/period_field" },
            "admission_period": { "$ref": "#/$defs/period_field" }
          },
          "additionalProperties": {
            "description": "New fields also use one of the three fixed shapes.",
            "oneOf": [
              { "$ref": "#/$defs/value_field" },
              { "$ref": "#/$defs/date_field" },
              { "$ref": "#/$defs/period_field" }
            ]
          }
        }
      },
      "required": ["fields"]
    }
  ],
  "$defs": {
    "field_common": {
      "type": "object",
      "properties": {
        "confidence": { "$ref": "common_component_output.schema.json#/$defs/confidence" },
        "evidence_references": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "common_component_output.schema.json#/$defs/evidence_reference" }
        },
        "review_required": { "type": "boolean" },
        "reviewer_role": { "$ref": "common_component_output.schema.json#/$defs/reviewer_role" },
        "is_primary": {
          "type": "boolean",
          "description": "For fields where multiple documents disagree (e.g. diagnosis_name/kcd_code): whether this is the primary (headline) value per the document-character-based priority rule in claim-analysis.md, as opposed to a secondary value kept alongside it. Absent when there's no disagreement to label."
        }
      },
      "required": ["confidence", "evidence_references", "review_required"]
    },
    "value_field": {
      "description": "Single-value shape: diagnosis name, KCD code, surgery name, hospital name, etc.",
      "allOf": [
        { "$ref": "#/$defs/field_common" },
        {
          "type": "object",
          "properties": {
            "value": { "type": ["string", "null"] },
            "normalized_value": {
              "type": "string",
              "description": "Normalized value, if applicable. e.g. lumbar_disc_herniation"
            }
          },
          "required": ["value"]
        }
      ]
    },
    "date_field": {
      "description": "Date shape: accident date, onset date, etc. value is YYYY-MM-DD.",
      "allOf": [
        { "$ref": "#/$defs/field_common" },
        {
          "type": "object",
          "properties": {
            "value": {
              "anyOf": [
                { "type": "string", "format": "date" },
                { "type": "null" }
              ]
            }
          },
          "required": ["value"]
        }
      ]
    },
    "period_field": {
      "description": "Period shape: treatment period, admission period, etc.",
      "allOf": [
        { "$ref": "#/$defs/field_common" },
        {
          "type": "object",
          "properties": {
            "start_date": { "type": "string", "format": "date" },
            "end_date": { "type": ["string", "null"], "format": "date" },
            "days": {
              "type": ["integer", "null"],
              "minimum": 1,
              "description": "Inclusive day count. null if end_date is unknown."
            }
          },
          "required": ["start_date", "end_date"]
        }
      ]
    }
  }
}
